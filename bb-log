#!/usr/bin/env bash
# bb-log — BetterBots log analysis tool
# Usage: bb-log [command] [log-index]
#   commands: activations, rules, holds, summary, errors, tail, list, raw <pattern>
#   log-index: 0=latest (default), 1=second-latest, etc.
set -euo pipefail

LOG_DIR="/run/media/matthias/58ACC87DACC856E2/Program Files (x86)/Steam/steamapps/compatdata/1361210/pfx/drive_c/users/steamuser/AppData/Roaming/Fatshark/Darktide/console_logs"
ERROR_LINE_PATTERN="<<Script Error>>|<<Lua Stack>>|<<Crash>>"

list_logs() {
    find "$LOG_DIR" -maxdepth 1 -type f -name 'console-*.log' -printf '%T@ %p\n' \
        | sort -rn \
        | cut -d' ' -f2-
}

get_log() {
    local idx="${1:-0}"
    local file
    file=$(list_logs | sed -n "$((idx + 1))p")
    if [[ -z "$file" ]]; then
        echo "No log found at index $idx" >&2
        exit 1
    fi
    echo "$file"
}

cmd="${1:-summary}"
if [[ "${cmd}" == "raw" ]]; then
    raw_pattern="${2:-BetterBots}"
    log_idx="${3:-0}"
else
    log_idx="${2:-0}"
fi

case "$cmd" in
    list)
        list_logs | head -10 | nl -v0 -ba
        exit 0
        ;;
    tail)
        log=$(get_log "$log_idx")
        echo "Tailing: $(basename "$log")"
        tail -f "$log" | grep --line-buffered -E "BetterBots|${ERROR_LINE_PATTERN}"
        ;;
esac

log=$(get_log "$log_idx")
echo "Log: $(basename "$log")"
echo "Lines: $(wc -l < "$log")"
echo ""

case "$cmd" in
    activations)
        rg "fallback queued|fallback item queued|fallback item blocked|charge consumed" "$log" || echo "(none)"
        ;;
    rules)
        echo "=== Activation rules ==="
        rg "fallback queued" "$log" | sed 's/.*rule=\([^,]*\),.*/\1/' | sort | uniq -c | sort -rn || echo "(none)"
        echo ""
        echo "=== Item queue steps ==="
        rg "fallback item queued" "$log" | sed 's/.*fallback item queued \(.*\) input=\([^ ]*\).*/\1 input=\2/' | sort | uniq -c | sort -rn || echo "(none)"
        echo ""
        echo "=== Item blocks ==="
        rg "fallback item blocked" "$log" | sed 's/.*fallback item blocked \(.*\) (\(.*\)).*/\1 (\2)/' | sort | uniq -c | sort -rn || echo "(none)"
        echo ""
        echo "=== Charge consumes ==="
        rg "charge consumed" "$log" | sed 's/.*for \([^ ]*\) .*/\1/' | sort | uniq -c | sort -rn || echo "(none)"
        ;;
    holds)
        echo "=== Active holds (nearby > 0) ==="
        rg "fallback held" "$log" | grep -v "nearby=0)" | sed 's/.*rule=\([^,]*\),.*/\1/' | sort | uniq -c | sort -rn || echo "(none)"
        ;;
    errors)
        rg "${ERROR_LINE_PATTERN}" "$log" || echo "(no errors found)"
        ;;
    summary)
        total_fallback_queued=$(rg -c "fallback queued" "$log" 2>/dev/null || echo 0)
        total_item_queued=$(rg -c "fallback item queued" "$log" 2>/dev/null || echo 0)
        total_item_blocked=$(rg -c "fallback item blocked" "$log" 2>/dev/null || echo 0)
        total_consumed=$(rg -c "charge consumed" "$log" 2>/dev/null || echo 0)
        total_held_active=$(rg "fallback held" "$log" 2>/dev/null | grep -vc "nearby=0)" 2>/dev/null || true)
        total_held_active="${total_held_active:-0}"
        total_held_idle=$(rg "fallback held" "$log" 2>/dev/null | grep -c "nearby=0)" 2>/dev/null || true)
        total_held_idle="${total_held_idle:-0}"
        total_error_lines=$(rg -c "${ERROR_LINE_PATTERN}" "$log" 2>/dev/null || echo 0)

        echo "Fallback queued: $total_fallback_queued | Item queued: $total_item_queued | Item blocked: $total_item_blocked | Consumed: $total_consumed | Held (combat): $total_held_active | Held (idle): $total_held_idle | Error lines: $total_error_lines"
        echo ""

        echo "=== Activations by rule ==="
        rg "fallback queued" "$log" 2>/dev/null | sed 's/.*rule=\([^,]*\),.*/\1/' | sort | uniq -c | sort -rn || echo "(none)"
        echo ""

        echo "=== Item queue steps ==="
        rg "fallback item queued" "$log" 2>/dev/null | sed 's/.*fallback item queued \(.*\) input=\([^ ]*\).*/\1 input=\2/' | sort | uniq -c | sort -rn || echo "(none)"
        echo ""

        echo "=== Item blocks ==="
        rg "fallback item blocked" "$log" 2>/dev/null | sed 's/.*fallback item blocked \(.*\) (\(.*\)).*/\1 (\2)/' | sort | uniq -c | sort -rn || echo "(none)"
        echo ""

        echo "=== Consumes by ability ==="
        rg "charge consumed" "$log" 2>/dev/null | sed 's/.*for \([^ ]*\) .*/\1/' | sort | uniq -c | sort -rn || echo "(none)"
        echo ""

        echo "=== Top holds (combat) ==="
        rg "fallback held" "$log" 2>/dev/null | grep -v "nearby=0)" | sed 's/.*rule=\([^,]*\),.*/\1/' | sort | uniq -c | sort -rn | head -10 || echo "(none)"
        ;;
    raw)
        rg "$raw_pattern" "$log" || echo "(no matches found)"
        ;;
    *)
        echo "Unknown command: $cmd"
        echo "Usage: bb-log [activations|rules|holds|summary|errors|tail|list|raw] [log-index]"
        echo "       bb-log raw <pattern> [log-index]"
        exit 1
        ;;
esac
