#!/usr/bin/env bash
# Validate commit messages against conventional commit format.
# Auto-installed by `make deps` via git config core.hooksPath.
set -euo pipefail

msg_file="$1"
msg=$(head -1 "$msg_file")

# Allow merge commits and reverts generated by git itself.
if [[ "$msg" =~ ^Merge\  ]] || [[ "$msg" =~ ^Revert\ \" ]]; then
  exit 0
fi

pattern='^(feat|fix|docs|refactor|perf|test|chore|ci|revert|style|build)(\([a-z0-9._-]+\))?!?: .+'

if ! [[ "$msg" =~ $pattern ]]; then
  echo >&2 "ERROR: commit message does not follow conventional commits."
  echo >&2 ""
  echo >&2 "  Expected: type(scope): description"
  echo >&2 "  Got:      $msg"
  echo >&2 ""
  echo >&2 "  Allowed types: feat fix docs refactor perf test chore ci revert style build"
  echo >&2 "  Scope is optional: feat(cli): add flag"
  echo >&2 "  Breaking change:  feat!: remove option"
  exit 1
fi

# Warn about GitHub closing keywords that would auto-close issues.
# Safe alternatives: "re #4", "see #4", "(#4)", or "Closes #4" on its own
# trailer line when you actually intend to close the issue.
closing_kw='(close[sd]?|fix(e[sd])?|resolve[sd]?)\s+#[0-9]+'
if grep -qiP "$closing_kw" "$msg_file"; then
  matches=$(grep -oiP "$closing_kw" "$msg_file" | head -5)
  echo >&2 "ERROR: commit message contains GitHub closing keyword(s):"
  echo >&2 ""
  echo >&2 "${matches//$'\n'/$'\n'  }"
  echo >&2 ""
  echo >&2 "  This will auto-close the referenced issue(s) on push."
  echo >&2 "  To reference without closing, use: re #N, see #N, or (#N)"
  echo >&2 "  To intentionally close, set CLOSE_ISSUES=1 before committing."
  if [[ "${CLOSE_ISSUES:-}" == "1" ]]; then
    echo >&2 "  CLOSE_ISSUES=1 set — proceeding."
  else
    exit 1
  fi
fi
