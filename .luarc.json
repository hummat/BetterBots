{
	"$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
	"runtime": {
		"version": "LuaJIT"
	},
	"diagnostics": {
		"globals": [
			"get_mod",
			"ScriptUnit"
		]
	},
	"workspace": {
		"checkThirdParty": false,
		"library": [
			"scripts"
		]
	},
	"format": {
		"enable": false
	},
	"telemetry": {
		"enable": false
	}
}
